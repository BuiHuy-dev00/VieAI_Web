{
  "name": "api-portal-backend",
  "version": "1.0.0",
  "description": "Gemini chatbot backend API",
  "main": "dist/server.js",
  "scripts": {
    "tsoa": "tsoa spec && tsoa routes",
    "dev": "npm run tsoa && nodemon --watch src --ext ts --ignore src/generated --exec 'npm run tsoa && ts-node src/server.ts'",
    "build": "npm run tsoa && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:seed-admin": "node scripts/seed-admin.cjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.5.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "openai": "^6.33.0",
    "pg": "^8.11.3",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
