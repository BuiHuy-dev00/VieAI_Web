NODE_ENV=development

# Tài khoản đăng nhập trang quản trị (/admin). Backend tạo/cập nhật user này khi khởi động.
# Đặt trong file .env cùng thư mục với docker-compose.yml (Compose đã nạp file đó cho service backend).
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=Admin123!
# ADMIN_NAME=Administrator

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chat_db
GEMINI_API_KEY=your_gemini_api_key_here

# Chat GPT (backend) — bắt buộc khi gửi tin qua /api/chat/...
# Với Docker: đặt ở đây HOẶC trong services/.env (compose đã nạp cả hai)
OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
# Thời hạn access token (khớp cookie access tối thiểu ~12h trên webapp). Ví dụ: 12h, 24h
# JWT_ACCESS_EXPIRES=12h

# Docker / backend — SePay (chỉ STK + mã NH như VCB; tên NH tự tra banks.json)
SEPAY_QR_ACCOUNT_NUMBER=
SEPAY_QR_BANK_CODE=VCB
