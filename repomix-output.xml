import { Pool } from 'pg';

const pool = new Pool({
  host: process.env.DB_HOST || 'localhost',
  port: parseInt(process.env.DB_PORT || '5432'),
  user: process.env.DB_USER || 'postgres',
  password: process.env.DB_PASSWORD || 'postgres',
  database: process.env.DB_NAME || 'chat_db',
});

export async function initDb(): Promise<void> {
  try {
    const client = await pool.connect();
    console.log('Database connected successfully');
    client.release();
  } catch (error) {
    console.error('Database connection failed:', error);
    throw error;
  }
}

export async function query<T>(text: string, params?: unknown[]): Promise<T[]> {
  const result = await pool.query(text, params);
  return result.rows as T[];
}

export async function queryOne<T>(text: string, params?: unknown[]): Promise<T | null> {
  const result = await pool.query(text, params);
  return (result.rows[0] as T) || null;
}

export { pool };
</file>

<file path="services/src/controllers/chat-controller.ts">
import { Request, Response, NextFunction } from 'express';
import { v4 as uuidv4 } from 'uuid';
import { query, queryOne } from '../config/db';
import {
  sendMessageStream,
  sendMessageWithImage,
  clearChatSession,
  ChatMessage,
  GeneratedImage
} from '../services/gemini-service';
import { createError } from '../middleware/error-handler';

interface Session {
  id: string;
  user_id: number;
  title: string;
  created_at: Date;
  updated_at: Date;
}

interface Message {
  id: number;
  session_id: string;
  role: string;
  content: string;
  image_data?: string;
  tokens_used: number;
  created_at: Date;
}

/**
 * Save image to database
 */
async function saveImage(sessionId: string, prompt: string, image: GeneratedImage): Promise<string> {
  const id = uuidv4();
  await query(
    `INSERT INTO images (id, session_id, prompt, image_url) VALUES ($1, $2, $3, $4)`,
    [id, sessionId, prompt, `data:${image.mimeType};base64,${image.data}`]
  );
  return id;
}

/**
 * Create new chat session
 */
export async function createSession(req: Request, res: Response, next: NextFunction) {
  try {
    const { userId = 1, title = 'New Chat' } = req.body;
    const id = uuidv4();

    await query(
      'INSERT INTO chat_sessions (id, user_id, title) VALUES ($1, $2, $3)',
      [id, userId, title]
    );

    const session = await queryOne<Session>(
      'SELECT * FROM chat_sessions WHERE id = $1',
      [id]
    );

    res.status(201).json({ success: true, data: session });
  } catch (error) {
    next(error);
  }
}

/**
 * Get session with messages
 */
export async function getSession(req: Request, res: Response, next: NextFunction) {
  try {
    const { id } = req.params;

    const session = await queryOne<Session>(
      'SELECT * FROM chat_sessions WHERE id = $1',
      [id]
    );

    if (!session) {
      throw createError('Session not found', 404);
    }

    const messages = await query<Message>(
      'SELECT * FROM messages WHERE session_id = $1 ORDER BY created_at ASC',
      [id]
    );

    // Get images for this session
    const images = await query<{ id: string; prompt: string; image_url: string }>(
      'SELECT id, prompt, image_url FROM images WHERE session_id = $1',
      [id]
    );

    res.json({ success: true, data: { ...session, messages, images } });
  } catch (error) {
    next(error);
  }
}

/**
 * Send message with streaming response + image generation
 */
export async function sendMessageHandler(req: Request, res: Response, next: NextFunction) {
  try {
    const { id } = req.params;
    const { message, stream = true } = req.body;

    if (!message) {
      throw createError('Message is required', 400);
    }

    // Verify session exists
    const session = await queryOne<Session>(
      'SELECT * FROM chat_sessions WHERE id = $1',
      [id]
    );

    if (!session) {
      throw createError('Session not found', 404);
    }

    // Get chat history for context
    const dbMessages = await query<Message>(
      'SELECT role, content FROM messages WHERE session_id = $1 ORDER BY created_at ASC',
      [id]
    );

    const history: ChatMessage[] = dbMessages.map(m => ({
      role: m.role === 'user' ? 'user' : 'model',
      parts: [{ text: m.content }]
    }));

    // Save user message
    await query(
      'INSERT INTO messages (session_id, role, content) VALUES ($1, $2, $3)',
      [id, 'user', message]
    );

    if (stream) {
      // Streaming response with image support
      res.setHeader('Content-Type', 'text/event-stream');
      res.setHeader('Cache-Control', 'no-cache');
      res.setHeader('Connection', 'keep-alive');

      let fullResponse = '';
      let generatedImageId: string | null = null;
      const generator = sendMessageStream(id, message, history);

      for await (const chunk of generator) {
        // Handle image chunk
        if (chunk.image) {
          generatedImageId = await saveImage(id, message, chunk.image);
          res.write(`data: ${JSON.stringify({
            type: 'image',
            imageId: generatedImageId,
            imageUrl: `data:${chunk.image.mimeType};base64,${chunk.image.data}`
          })}\n\n`);
        }

        // Handle text chunk
        if (chunk.text) {
          fullResponse += chunk.text;
          res.write(`data: ${JSON.stringify({ type: 'text', text: chunk.text, done: false })}\n\n`);
        }

        if (chunk.done) {
          res.write(`data: ${JSON.stringify({ type: 'done', done: true })}\n\n`);
        }
      }

      // Save assistant response
      await query(
        'INSERT INTO messages (session_id, role, content) VALUES ($1, $2, $3)',
        [id, 'assistant', fullResponse]
      );

      // Update session timestamp
      await query(
        'UPDATE chat_sessions SET updated_at = NOW() WHERE id = $1',
        [id]
      );

      res.end();
    } else {
      // Non-streaming response with image support
      const response = await sendMessageWithImage(id, message, history);

      let imageId: string | null = null;
      let imageUrl: string | null = null;

      // Save image if generated
      if (response.image) {
        imageId = await saveImage(id, message, response.image);
        imageUrl = `data:${response.image.mimeType};base64,${response.image.data}`;
      }

      // Save assistant response
      await query(
        'INSERT INTO messages (session_id, role, content) VALUES ($1, $2, $3)',
        [id, 'assistant', response.text]
      );

      // Update session timestamp
      await query(
        'UPDATE chat_sessions SET updated_at = NOW() WHERE id = $1',
        [id]
      );

      res.json({
        success: true,
        data: {
          response: response.text,
          ...(imageId && { imageId, imageUrl })
        }
      });
    }
  } catch (error) {
    next(error);
  }
}

/**
 * Delete session
 */
export async function deleteSession(req: Request, res: Response, next: NextFunction) {
  try {
    const { id } = req.params;

    const result = await query(
      'DELETE FROM chat_sessions WHERE id = $1 RETURNING id',
      [id]
    );

    if (result.length === 0) {
      throw createError('Session not found', 404);
    }

    clearChatSession(id);
    res.json({ success: true, message: 'Session deleted' });
  } catch (error) {
    next(error);
  }
}

/**
 * List all sessions for a user
 */
export async function listSessions(req: Request, res: Response, next: NextFunction) {
  try {
    const { userId = 1 } = req.query;

    const sessions = await query<Session>(
      'SELECT * FROM chat_sessions WHERE user_id = $1 ORDER BY updated_at DESC',
      [userId]
    );

    res.json({ success: true, data: sessions });
  } catch (error) {
    next(error);
  }
}
